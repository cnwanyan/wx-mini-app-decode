.mask{-webkit-box-pack:center;-webkit-box-align:center;align-items:center;background:rgba(0,0,0,.6);display:-webkit-box;display:-webkit-flex;display:flex;height:100%;justify-content:center;left:0;position:fixed;top:0;width:100%;z-index:999}.main-img{border-radius:8rpx;width:100%}.hll-dialog,.main-img{box-shadow:0 0 38rpx 0 rgba(108,140,173,.3)}.hll-dialog{background:#fff;border-radius:20rpx 20rpx 16rpx 16rpx;position:relative;width:590rpx}.hll-dialog .close{height:46rpx;position:absolute;right:24rpx;top:24rpx;width:46rpx}.title{color:#17161c;font-family:PingFangSC-Medium,PingFang SC;font-size:40rpx;font-weight:500;line-height:44rpx;padding-left:48rpx;padding-top:56rpx}.content,.title{position:relative}.content{color:#333;font-family:PingFang-SC-Regular,PingFang-SC;font-size:32rpx;line-height:50rpx;padding:40rpx;text-align:center}.content .cont-txt{display:inline-block}.bottom-btn{border-top:1rpx solid #e0e0e0;display:-webkit-box;display:-webkit-flex;display:flex;font-size:32rpx;height:98rpx;line-height:98rpx}.bottom-btn .btn{-webkit-box-flex:1;flex:1;font-size:32rpx;text-align:center}.center-btn{font-size:32rpx;padding-bottom:40rpx}.center-btn,.center-btn .btn-box{-webkit-box-orient:horizontal;-webkit-box-direction:normal;-webkit-box-pack:center;display:-webkit-box;display:-webkit-flex;display:flex;flex-direction:row;justify-content:center}.center-btn .btn-box{-webkit-box-align:center;align-items:center;background-color:#f60;border-radius:8rpx;height:96rpx;width:480rpx}.center-btn .btn-box .btn-txt{color:#fff;font-family:PingFangSC-Semibold,PingFang SC;font-size:32rpx;font-weight:700;line-height:36rpx}.cancel{color:#333;font-family:PingFangSC-Regular;position:relative}.cancel::before{background:#e0e0e0;content:"";height:100%;position:absolute;right:0;top:50%;transform:translateY(-50%);width:1rpx}.confirm{color:#ff732d;font-family:PingFangSC-Semibold;font-weight:660}