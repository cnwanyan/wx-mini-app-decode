.policy-popup{-webkit-box-pack:center;-webkit-box-align:center;align-items:center;background:rgba(0,0,0,.7);display:-webkit-box;display:-webkit-flex;display:flex;height:100%;justify-content:center;left:0;overflow:hidden;position:fixed;top:0;width:100%;z-index:1001}.policy-popup .modal-content{background:#fff;border-radius:20rpx 20rpx 16rpx 16rpx;box-sizing:border-box;padding:0 40rpx 20rpx;position:relative;width:640rpx}.policy-popup .modal-content .title{color:#333;font-family:PingFangSC-Medium;font-size:32rpx;font-weight:500;height:52rpx;letter-spacing:0;line-height:52rpx;padding:50rpx 0 32rpx;text-align:center}.policy-popup .modal-content .desc{color:#666;font-family:PingFangSC;font-size:28rpx;font-weight:400;line-height:52rpx;text-align:left;word-break:break-all}.policy-popup .modal-content .highlight{color:#f60;font-weight:600}.policy-popup .modal-content .btn{height:100rpx;justify-content:space-around;margin-top:30rpx;width:100%}.policy-popup .modal-content .btn,.policy-popup .modal-content .btn__item{-webkit-box-align:center;align-items:center;display:-webkit-box;display:-webkit-flex;display:flex}.policy-popup .modal-content .btn__item{-webkit-box-pack:center;background-color:#fff;color:#999;font-family:PingFangSC-Regular;font-size:30rpx;font-weight:400;height:88rpx;justify-content:center;margin:0;width:46%}.policy-popup .modal-content .btn__agree{background-color:#f60;color:#fff;font-weight:500}