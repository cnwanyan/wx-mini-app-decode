<view catchtouchmove="preventTouchMove" class="mask" wx:if="{{isShow}}">
    <view class="modal-content">
        <view bindtap="__e" class="close" data-event-opts="{{[ [ 'tap',[ [ 'closedX',['$event'] ] ] ] ]}}">
            <image alt class="img" src="/static/img/modal-close.png"></image>
        </view>
        <view class="title">{{type===3?'':'关于优惠加油服务协议'}}</view>
        <view class="title" wx:if="{{type===1}}">更新的意见征询</view>
        <view class="title" wx:if="{{type===2}}">更新的公示</view>
        <view class="desc">亲爱的用户，您好！感谢您对优惠加油的长期关注与支持。</view>
        <view class="desc" wx:if="{{type===1}}">现就此更新调整进行意见征集。请您点击并仔细阅读相关协议内容。</view>
        <view class="desc" wx:if="{{type===2}}">请您点击并仔细阅读相关协议内容。</view>
        <view class="desc" wx:if="{{type===3}}">在继续使用优惠加油服务前，请您务必仔细阅读相关协议内容（尤其是其中责任免除或限制的约定及其他以加粗或颜色标识的重要条款）。若您对协议各条款及内容有任何疑问，请您联系在线客服。</view>
        <view class="desc" wx:if="{{type===1}}">若您对协议各条款及内容有任何疑问、意见或建议，请您在<text class="hightlight-info">2023年1月15日23:59:59</text>前将相关意见发送至意见征询指定邮<text class="hightlight-info">yhjyyj@huolala.cn</text>
        </view>
        <view class="desc" wx:if="{{type===2}}">若您对协议各条款及内容有任何疑问、意见或建议，请您在<text class="hightlight-info">2022年1月22日23:59:59</text>前联系在线客服。</view>
        <view class="desc" wx:if="{{type===3}}">
            <text class="hightlight-info">【特别提示】</text>若您按照提示完成登录并继续使用优惠加油相关服务，即表示您已充分阅读、理解并接受各协议内全部内容。若您不同意相关协议内容，请您立即停止登录及使用相关服务。</view>
        <view class="desc" wx:if="{{type===1||type===2}}">
            <view class="text__algin">货拉拉</view>
            <view class="text__algin">2023年1月9日</view>
        </view>
        <view bindtap="__e" class="confirm _p" data-event-opts="{{[ [ 'tap',[ [ 'btnEvent',['$event'] ] ] ] ]}}" wx:if="{{type===1||type===2}}">我知道了</view>
        <block wx:if="{{type===3}}">
            <view bindtap="__e" class="{{['confirm','_p',btnDisabled||confirm===false?'disabled':'']}}" data-event-opts="{{[ [ 'tap',[ [ 'btnEvent',['$event'] ] ] ] ]}}">{{'已知悉并同意 '+(btnDisabled&&countdown>0?'('+countdown+'s)':'')+''}}</view>
            <view class="button">
                <label bindtap="__e" class="{{['checkbox','_span',confirm?'active':'']}}" data-event-opts="{{[ [ 'tap',[ [ 'checkboxConfirm',['$event'] ] ] ] ]}}"></label>我已充分阅读并接受<text bindtap="__e" class="highlight" data-event-opts="{{[ [ 'tap',[ [ 'openLink',[link+'/pages/policy/information'] ] ] ] ]}}">《优惠加油（信息）服务协议》</text>
                <text bindtap="__e" class="highlight" data-event-opts="{{[ [ 'tap',[ [ 'openLink',[link+'/pages/policy/market-privacy-new'] ] ] ] ]}}">和《货拉拉优惠加油隐私政策》</text>全部内容。</view>
        </block>
    </view>
</view>
