<view bindtap="__e" class="store-line data-v-467506aa" data-event-opts="{{[ [ 'tap',[ [ 'lineHandle',['$event'] ] ] ] ]}}">
    <view class="line-lf data-v-467506aa">
        <image class="store-logo data-v-467506aa" lazyLoad="true" mode="aspectFill" src="{{config.store_logo}}"></image>
    </view>
    <view class="line-rf data-v-467506aa">
        <view class="name data-v-467506aa">{{config.store_name||'-'}}</view>
        <view class="address data-v-467506aa">{{config.addr||'-'}}</view>
        <view class="time data-v-467506aa">{{'营业时间：'+(config.bussiness_time||'-')}}</view>
        <view class="lbs data-v-467506aa">
            <view class="lbs-lf data-v-467506aa">
                <image class="badge-icon data-v-467506aa" lazyLoad="true" mode="widthFix" src="https://ops-img-static.huolala.cn/imgs/2021/163063996018806992436654.png"></image>
                <view class="server-desc data-v-467506aa">{{'已服务'+config.sale_count+'单'}}</view>
            </view>
            <view catchtap="__e" class="lbs-rf data-v-467506aa" data-event-opts="{{[ [ 'tap',[ [ 'goLbs',['$0'],['config'] ] ] ] ]}}">
                <image class="lbs-icon data-v-467506aa" lazyLoad="true" mode="widthFix" src="https://ops-img-static.huolala.cn/imgs/2021/162961534823377518517662.png"></image>
                <view class="distance data-v-467506aa">{{config.distance+'km'}}</view>
            </view>
        </view>
    </view>
    <view class="store-status data-v-467506aa" wx:if="{{storeId===config.store_id}}">
        <image class="store-img data-v-467506aa" lazyLoad="true" src="https://ops-img-static.huolala.cn/imgs/2021/163512799411728380131474.png"></image>
    </view>
</view>
